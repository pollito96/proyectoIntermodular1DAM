<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aescenaapp.controlador.AdminControlador"
      style="-fx-background-color: #ecf0f1; -fx-padding: 20;">

    <Label text="Panel de Administración"
           style="-fx-font-size: 22px; -fx-font-weight: bold;" />

    <Label fx:id="modoLabel"
           text="Vista actual: Clientes"
           style="-fx-font-size: 14px; -fx-text-fill: #555;" />

    <HBox spacing="10">

        <ToggleButton fx:id="btnClientes"
                      text="Clientes"
                      selected="true"
                      onAction="#verClientes"
                      maxWidth="150" />

        <ToggleButton fx:id="btnProfesores"
                      text="Profesores"
                      onAction="#verProfesores"
                      maxWidth="150" />

        <Button fx:id="btnExportarXML"
                text="Exportar sesiones a XML"
                onAction="#exportarXML"
                style="-fx-padding: 8;" />

    </HBox>

    <TableView fx:id="tablaUsuarios"
                VBox.vgrow="ALWAYS"
                prefHeight="400">

        <columns>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="250"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
        </columns>

    </TableView>

</VBox>