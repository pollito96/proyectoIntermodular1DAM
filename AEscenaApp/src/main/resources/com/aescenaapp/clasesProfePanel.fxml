<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aescenaapp.controlador.ClasesProfeControlador"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <Label text="Panel de Profesor - Clases y Sesiones"
               style="-fx-font-size: 20px; -fx-padding: 10;" />
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 15;">

            <VBox spacing="10" prefWidth="400">

                <Label text="Catálogo de Clases"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                <TableView fx:id="tablaClases" prefHeight="400">

                    <columns>
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="350"/>
                    </columns>

                </TableView>

            </VBox>

            <VBox spacing="10" prefWidth="350">

                <Label text="Crear Sesión"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;" />

                <Label text="Clase seleccionada:" />

                <Label fx:id="lblClaseSeleccionada"
                       text="Ninguna"
                       style="-fx-font-weight: bold;" />

                <Separator/>

                <Label text="Fecha" />
                <DatePicker fx:id="datePicker"/>

                <Label text="Hora inicio" />
                <ComboBox fx:id="horaInicioCombo" />

                <Label text="Hora fin" />
                <ComboBox fx:id="horaFinCombo" />

                <Label text="Plazas" />
                <TextField fx:id="plazasField"
                           promptText="Número de plazas" />

                <Button text="Crear sesión"
                        onAction="#crearSesion"
                        maxWidth="Infinity"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;" />

            </VBox>

        </HBox>
    </center>

</BorderPane>