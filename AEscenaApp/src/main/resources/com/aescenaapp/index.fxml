<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.aescenaapp.controlador.IndexControlador">

    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2c3e50;">
            <Label text="AEscena Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 18px;" />

            <Pane HBox.hgrow="ALWAYS"/>

            <Label fx:id="usuarioLabel"
                   style="-fx-text-fill: white;" />
        </HBox>
    </top>

    <left>
        <VBox spacing="10"
              style="-fx-padding: 15; -fx-background-color: #34495e;"
              prefWidth="200">

            <Button fx:id="btnReservas"
                    text="Reservas"
                    maxWidth="Infinity"
                    onAction="#irReservas"
            />

            <Button fx:id="btnSesiones"
                    text="Sesiones"
                    maxWidth="Infinity"
                    onAction="#irSesiones"
            />

            <Button fx:id="btnClasesProfe"
                    text="Clases"
                    maxWidth="Infinity"
                    onAction="#irClasesProfe"
            />

            <Button fx:id="btnClasesAdmin"
                    text="Gestion Clases"
                    maxWidth="Infinity"
                    onAction="#irClasesAdmin"
            />

            <Button fx:id="btnAdmin"
                    text="Administración"
                    maxWidth="Infinity"
                    onAction="#irAdmin"
            />

            <Separator/>

            <Button text="Cerrar sesión"
                    onAction="#logout"
                    maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane"
                   style="-fx-padding: 20;"/>
    </center>

</BorderPane>