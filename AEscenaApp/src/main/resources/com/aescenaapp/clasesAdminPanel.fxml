<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aescenaapp.controlador.ClasesAdminControlador"
      style="-fx-background-color: #ecf0f1; -fx-padding: 20;">


    <Label text="Gestión de Clases"
           style="-fx-font-size: 22px; -fx-font-weight: bold;" />


    <HBox spacing="10">

        <Button text="Añadir clase"
                onAction="#onCrearClase"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />

        <Button text="Editar clase"
                onAction="#onEditarClase"
                style="-fx-background-color: #f1c40f; -fx-text-fill: white;" />

        <Button text="Eliminar clase"
                onAction="#onEliminarClase"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />

    </HBox>

    <!-- TABLA DE CLASES -->
    <TableView fx:id="tablaClases">

        <columns>

            <TableColumn fx:id="colNombre"
                         text="Nombre"
                         prefWidth="200" />

            <TableColumn fx:id="colDescripcion"
                         text="Descripción"
                         prefWidth="400" />

        </columns>

    </TableView>

</VBox>