<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER"
      prefHeight="600"
      prefWidth="900"
      spacing="20"
      style="-fx-background-color: #2c3e50;"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.aescenaapp.controlador.RegistroControlador">

    <VBox alignment="CENTER" spacing="5">
        <Label text="AEscena"
               style="-fx-font-size: 28px;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;" />

        <Label text="Registro"
               style="-fx-font-size: 16px;
                      -fx-text-fill: #bdc3c7;" />
    </VBox>

    <VBox alignment="CENTER"
          spacing="12"
          maxWidth="320"
          style="-fx-background-color: #34495e;
                 -fx-padding: 25;
                 -fx-background-radius: 10;">

        <HBox>
            <Label text="Email" style="-fx-text-fill: white;" />
            <Label fx:id="emailErrorLabel"
                       textFill="#e74c3c"
                       style="-fx-padding: 5;" />
        </HBox>
        <TextField fx:id="emailField"
                   promptText="ejemplo@gmail.com"
                   style="-fx-background-radius: 5;
                   -fx-padding: 8;" />

        <HBox>
            <Label text="Nombre" style="-fx-text-fill: white;" />
            <Label fx:id="nombreErrorLabel"
                   textFill="#e74c3c"
                   style="-fx-padding: 5;" />
        </HBox>
        <TextField fx:id="nombreField"
                   promptText="Ejemplo"
                   style="-fx-background-radius: 5;
                          -fx-padding: 8;" />

        <HBox>
            <Label text="Contraseña" style="-fx-text-fill: white;" />
            <Label fx:id="passwordErrorLabel"
                   textFill="#e74c3c"
                   style="-fx-padding: 5;" />
        </HBox>
        <PasswordField fx:id="passwordField"
                       promptText="Contraseña"
                       style="-fx-background-radius: 5;
                              -fx-padding: 8;" />

        <HBox spacing="10" alignment="CENTER">

            <Button fx:id="registrarButton"
                    text="Registrarse"
                    onAction="#registrar"
                    defaultButton="true"
                    style="-fx-background-color: #1abc9c;
                           -fx-text-fill: white;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;" />

            <Button text="Ya tengo cuenta"
                    onAction="#redireccionLogin"
                    style="-fx-background-color: #3498db;
                           -fx-text-fill: white;
                           -fx-background-radius: 5;
                           -fx-cursor: hand;" />

        </HBox>

        <Label fx:id="errorLabel"
               textFill="#e74c3c"
               style="-fx-padding: 5;" />

    </VBox>

</VBox>