<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="600" prefWidth="900" spacing="10" style="-fx-padding: 30;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.aescenaapp.controlador.RegistroControlador">
   <VBox alignment="CENTER" spacing="15.0">
      <children>
         <Label contentDisplay="CENTER" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="AEscena" />
      
        <Label contentDisplay="CENTER" style="-fx-font-size: 20px;" text="Registro" />
      </children>
      <VBox.margin>
         <Insets bottom="70.0" top="70.0" />
      </VBox.margin>
   </VBox>
   <VBox alignment="CENTER" maxWidth="400.0" spacing="10.0">
      <children>
         <VBox alignment="CENTER_LEFT">
            <children>
            
              <Label text="Email" />
              <TextField fx:id="emailField" maxWidth="400.0" promptText="ejemplo@gmail.com" />
            </children>
         </VBox>
          <VBox alignment="CENTER_LEFT">
              <children>

                  <Label text="Nombre" />
                  <TextField fx:id="nombreField" maxWidth="400.0" promptText="Ejemplo" />
              </children>
          </VBox>
         <VBox alignment="CENTER_LEFT">
            <children>
            
              <Label text="Contraseña" />
              <PasswordField fx:id="passwordField" maxWidth="400.0" promptText="Contraseña" />
            </children>
         </VBox>
         <HBox alignment="CENTER" spacing="20.0">
            <children>
            
              <Button onAction="#login" text="Iniciar sesión" />
              <Button onAction="#redireccionLogin" text="Ya tengo una cuenta" />
            </children>
         </HBox>
      
        <Label fx:id="errorLabel" textFill="red" />
      </children>
   </VBox>

</VBox>
