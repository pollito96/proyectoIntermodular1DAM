<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.aescenaapp.controlador.SesionControlador"
            style="-fx-background-color: #ecf0f1;">

    <top>
        <VBox spacing="5" style="-fx-padding: 10;">

            <Label text="Panel de Sesiones"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <Label fx:id="titleLabel"
                   text="Tus Sesiones"
                   style="-fx-text-fill: #555;" />

        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 10;">

            <HBox spacing="10">

                <Button fx:id="btnTodas"
                        text="Todas"
                        onAction="#filtrarTodas"/>

                <Button fx:id="btnCreadas"
                        text="Creadas"
                        onAction="#filtrarCreadas"/>

                <Button fx:id="btnReservadas"
                        text="Reservadas"
                        onAction="#filtrarReservadas"/>

            </HBox>

            <TableView fx:id="tablaSesiones" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colClase" text="Clase" prefWidth="150"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="120"/>
                    <TableColumn fx:id="colInicio" text="Inicio" prefWidth="80"/>
                    <TableColumn fx:id="colFin" text="Fin" prefWidth="80"/>
                    <TableColumn fx:id="colPlazas" text="Plazas" prefWidth="100"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                </columns>
            </TableView>

        </VBox>
    </center>

</BorderPane>